@import "layoutVars"
#g-app-body-container
  padding-top 90px !important

#g-app-body-container.g-default-layout
  padding-top 90px !important
  
#g-app-header-container
  background #ffffff !important
  background-image none !important
  height 74px !important
  border-bottom 1px solid rgba(37,99,235,0.18) !important
  box-shadow 0 8px 24px rgba(22,50,79,0.10) !important
  z-index 1000

#g-app-header-container .g-header-wrapper
  background #ffffff !important
  background-image none !important
  height 74px !important
  display flex
  align-items center
  gap 24px
  padding 0 28px

#g-app-header-container *
  text-shadow none !important

#g-app-header-container .g-app-title
  color #16324F !important
  font-size 25px
  font-weight 900
  letter-spacing -0.7px

.g-quick-search-container
  flex 0 0 330px

.g-quick-search-form
  height 46px
  overflow hidden
  border-radius 18px
  background #f8fbfd
  border 1px solid rgba(37,99,235,0.18)

.g-quick-search-form input
  height 46px !important
  border none !important
  background transparent !important
  color #16324F !important
  font-size 15px
  box-shadow none !important

.g-quick-search-form button,
.g-quick-search-form .input-group-addon,
.g-quick-search-form .btn
  border none !important
  background transparent !important
  color #2563EB !important

#g-app-header-container .g-current-user-wrapper
  margin-left auto
  display flex
  align-items center
  height 74px

#g-app-header-container .g-current-user-wrapper a
  color #16324F !important
