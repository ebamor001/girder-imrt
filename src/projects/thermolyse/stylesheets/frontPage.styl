
.g-landing-page-active
  #g-app-header-container,
  #g-global-nav-container,
  #g-app-footer-container
    display none !important

  #g-app-body-container
    margin-left 0 !important
    padding 0 !important

.g-project-shell,
.g-dashboard-shell
  --primary #193A5A
  --secondary #E76F51
  --accent #2A9D8F
  --soft #fff3ee
  --border rgba(231,111,81,0.18)
  --shadow rgba(25,58,90,0.10)
  min-height 100vh
  padding 28px
  background linear-gradient(180deg, #f8fbff 0%, var(--soft) 100%)
  color #243447
  font-family 'Inter', 'Segoe UI', Tahoma, sans-serif

.g-project-container
  max-width 1180px
  margin 0 auto

.g-topbar
  display flex
  align-items center
  justify-content space-between
  gap 20px
  padding 20px 24px
  margin-bottom 28px
  background rgba(255,255,255,0.94)
  border 1px solid var(--border)
  border-radius 28px
  box-shadow 0 14px 40px var(--shadow)

.g-brand
  display flex
  align-items center
  gap 16px
  min-width 0

.g-brand-logo
  width 66px
  height 66px
  border-radius 22px
  background white
  border 1px solid var(--border)
  box-shadow 0 12px 30px var(--shadow)
  padding 7px
  object-fit contain

.g-brand-title
  margin 0
  color var(--primary)
  font-size 26px
  font-weight 900
  letter-spacing -0.5px

.g-brand-subtitle
  margin 5px 0 0
  color #64748b
  font-size 14px
  line-height 1.35

.g-actions
  display flex
  align-items center
  justify-content flex-end
  gap 10px
  flex-wrap wrap

.g-btn
  height 42px
  border none
  border-radius 13px
  padding 0 18px
  color white
  background var(--primary)
  font-size 14px
  font-weight 800
  cursor pointer
  white-space nowrap
  transition all 0.18s ease

  &:hover
    transform translateY(-2px)
    box-shadow 0 10px 22px var(--shadow)

.g-btn-secondary
  background var(--secondary)

.g-language-switcher
  min-width 58px
  background #ffffff
  color var(--primary)
  border 1px solid var(--border)

.g-hero
  position relative
  overflow hidden
  display grid
  grid-template-columns 1.4fr 0.6fr
  gap 36px
  align-items center
  padding 64px
  color white
  border-radius 34px
  background radial-gradient(circle at 80% 10%, rgba(255,255,255,0.22), transparent 24%), linear-gradient(135deg, var(--primary), var(--secondary))
  box-shadow 0 26px 70px var(--shadow)

.g-hero-kicker
  display inline-flex
  align-items center
  gap 8px
  padding 9px 14px
  margin-bottom 20px
  color white
  font-weight 850
  border 1px solid rgba(255,255,255,0.34)
  border-radius 999px
  background rgba(255,255,255,0.15)

.g-hero h1
  margin 0 0 16px
  font-size 56px
  line-height 1
  font-weight 950
  letter-spacing -1.8px

.g-hero p
  margin 0
  max-width 760px
  font-size 20px
  line-height 1.65
  opacity 0.95

.g-hero-buttons
  display flex
  flex-wrap wrap
  gap 14px
  margin-top 30px

.g-hero-button
  display inline-flex
  align-items center
  justify-content center
  height 48px
  border-radius 15px
  padding 0 24px
  background white
  color var(--primary)
  border none
  font-weight 900
  text-decoration none
  cursor pointer

.g-hero-button-alt
  background rgba(255,255,255,0.16)
  color white
  border 1px solid rgba(255,255,255,0.36)

.g-hero-card
  background rgba(255,255,255,0.16)
  border 1px solid rgba(255,255,255,0.28)
  border-radius 28px
  padding 26px

.g-hero-project-logo
  width 108px
  height 108px
  display block
  object-fit contain
  padding 12px
  border-radius 26px
  background white
  margin-bottom 20px

.g-meta-line
  display flex
  gap 10px
  align-items flex-start
  margin 12px 0
  font-size 14px
  line-height 1.4

.g-section
  margin-top 30px
  padding 40px
  border-radius 30px
  background rgba(255,255,255,0.97)
  border 1px solid var(--border)
  box-shadow 0 18px 50px var(--shadow)

.g-section-header
  display flex
  align-items center
  gap 14px
  margin-bottom 24px

.g-section-icon
  width 48px
  height 48px
  display flex
  align-items center
  justify-content center
  border-radius 16px
  color white
  background linear-gradient(135deg, var(--primary), var(--secondary))
  font-size 22px

.g-section h2
  margin 0
  color var(--primary)
  font-size 28px
  font-weight 950

.g-section-lead
  color #536579
  font-size 17px
  line-height 1.8
  margin 0

.g-info-grid
  display grid
  grid-template-columns repeat(auto-fit, minmax(220px, 1fr))
  gap 16px
  margin-top 28px

.g-info-pill
  padding 18px
  border-radius 20px
  background linear-gradient(180deg, white, #f8fafc)
  border 1px solid var(--border)

  strong
    display block
    color var(--primary)
    margin-bottom 5px

  span
    color #64748b
    line-height 1.45

.g-card-grid
  display grid
  grid-template-columns repeat(auto-fit, minmax(230px, 1fr))
  gap 18px

.g-feature-card
  padding 24px
  min-height 170px
  border-radius 22px
  background #f8fafc
  border 1px solid rgba(148,163,184,0.18)
  transition all 0.2s ease

  &:hover
    transform translateY(-5px)
    background white
    box-shadow 0 16px 36px var(--shadow)

.g-feature-emoji
  font-size 34px
  margin-bottom 16px

.g-feature-card h3
  margin 0 0 10px
  color var(--primary)
  font-size 18px
  font-weight 900

.g-feature-card p
  margin 0
  color #64748b
  line-height 1.55

.g-partners
  display grid
  grid-template-columns repeat(auto-fit, minmax(180px, 1fr))
  gap 18px

.g-partner-card
  display flex
  flex-direction column
  justify-content space-between
  min-height 160px
  padding 22px
  border-radius 22px
  background white
  border 1px solid var(--border)

.g-partner-logo-wrap
  height 68px
  display flex
  align-items center
  justify-content center
  margin-bottom 16px

.g-partner-logo
  max-width 150px
  max-height 66px
  object-fit contain

.g-partner-card strong
  color var(--primary)

.g-partner-card span
  display block
  color #64748b
  font-size 13px
  margin-top 4px

.g-work-grid
  display grid
  grid-template-columns repeat(auto-fit, minmax(260px, 1fr))
  gap 22px

.g-work-card
  position relative
  padding 28px
  border-radius 24px
  border 1px solid var(--border)
  background linear-gradient(180deg, #ffffff, #f8fafc)

  &:before
    content ''
    position absolute
    left 0
    top 26px
    bottom 26px
    width 5px
    border-radius 999px
    background var(--secondary)

.g-work-card h3
  margin 0 0 12px
  color var(--primary)
  font-weight 950

.g-work-card p
  margin 0
  color #536579
  line-height 1.65

.g-dashboard-hero
  padding 40px
  border-radius 30px
  color white
  background linear-gradient(135deg, var(--primary), var(--secondary))
  box-shadow 0 22px 60px var(--shadow)

.g-dashboard-topbar
  display flex
  align-items center
  justify-content space-between
  margin-bottom 26px

.g-dashboard-brand
  display flex
  align-items center
  gap 12px
  font-size 18px
  font-weight 900

  img
    width 46px
    height 46px
    border-radius 14px
    background white
    padding 5px
    object-fit contain

.g-dashboard-hero h1
  margin 0 0 10px
  font-size 42px
  font-weight 950

.g-dashboard-hero p
  margin 0
  font-size 19px
  opacity .95

.g-dashboard-grid
  display grid
  grid-template-columns repeat(auto-fit, minmax(240px, 1fr))
  gap 20px
  margin-top 26px

.g-dashboard-card
  padding 28px
  min-height 170px
  color #243447
  text-decoration none
  border-radius 24px
  background white
  border 1px solid var(--border)
  box-shadow 0 18px 45px var(--shadow)
  transition all .2s ease

  &:hover
    transform translateY(-5px)

.g-dashboard-card span
  font-size 34px

.g-dashboard-card h3
  margin 18px 0 10px
  color var(--primary)
  font-size 21px
  font-weight 950

.g-dashboard-card p
  margin 0
  color #64748b
  line-height 1.55

@media (max-width: 850px)
  .g-project-shell,
  .g-dashboard-shell
    padding 16px

  .g-topbar
    flex-direction column
    text-align center

  .g-brand
    flex-direction column

  .g-actions
    justify-content center

  .g-hero
    grid-template-columns 1fr
    padding 42px 24px
    text-align center

  .g-hero h1
    font-size 42px

  .g-hero-buttons
    justify-content center

  .g-section
    padding 26px

.g-dashboard-section
  margin-top 28px
  padding 34px
  background white
  border 1px solid var(--border)
  border-radius 28px
  box-shadow 0 16px 45px var(--shadow)
  text-align center

  h2
    margin 0 0 24px
    color var(--primary)
    font-size 26px
    font-weight 950

.g-contact-alert
  padding 16px
  margin-bottom 22px
  border-left 5px solid var(--secondary)
  border-radius 14px
  background #fff7df
  color #536579
  font-style italic

.g-contact-grid,
.g-stats-grid
  display grid
  grid-template-columns repeat(auto-fit, minmax(220px, 1fr))
  gap 20px

.g-contact-card,
.g-stat-card
  padding 24px
  border-radius 20px
  background #f8fafc
  border 1px solid var(--border)

.g-contact-card strong,
.g-stat-card strong
  display block
  color var(--primary)
  font-size 18px
  font-weight 900

.g-contact-card span,
.g-stat-card span
  display block
  margin-top 6px
  color #64748b

.g-contact-card a
  display block
  margin-top 8px
  color var(--secondary)
  font-weight 800

.g-stat-card strong
  color var(--secondary)
  font-size 28px

.g-quick-actions
  display flex
  justify-content center
  gap 16px
  flex-wrap wrap

.g-action-btn
  padding 14px 22px
  border-radius 14px
  background linear-gradient(135deg, var(--secondary), var(--primary))
  color white
  font-weight 900
  text-decoration none
  box-shadow 0 12px 28px var(--shadow)

  &:hover
    color white
    text-decoration none
    transform translateY(-2px)

  
.g-dashboard-shell
  padding-top 96px
  padding-left 28px
  padding-right 28px

.g-dashboard-shell .g-project-container
  max-width 1180px
  margin 0 auto