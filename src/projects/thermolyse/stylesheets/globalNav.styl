$navLinkBorder=1px solid rgba(231,111,81,0.18)
$emptyBorder=1px solid transparent
$minHeight=500px

#g-global-nav-container
  background #ffffff
  border-right 1px solid rgba(231,111,81,0.18)
  box-shadow 8px 0 28px rgba(25,58,90,0.10)

.g-global-nav-main
  min-height $minHeight - 12px
  padding 24px 12px
  background #ffffff
  box-shadow none

ul.g-global-nav
  padding-left 0
  margin 0

  > li
    list-style-type none
    border $emptyBorder
    margin 8px 0
    border-radius 16px
    transition all 0.2s ease

  > li:hover:not(.g-active)
    background #fff3ee

    .g-nav-link
      color #E76F51

    i
      color #E76F51

  > li.g-active
    background #fff3ee
    border $navLinkBorder
    box-shadow 0 8px 20px rgba(25,58,90,0.10)

    .g-nav-link
      color #193A5A

    i
      color #E76F51

.g-nav-link
  display flex
  align-items center
  gap 10px
  padding 13px 16px
  line-height 1.4
  font-size 17px
  font-weight 700
  color #193A5A
  text-decoration none

  &:hover
    text-decoration none

  i
    color #E76F51
    font-size 18px
    margin 0
