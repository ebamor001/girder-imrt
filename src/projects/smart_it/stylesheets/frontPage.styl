.g-landing-page-active
  #g-app-header-container,
  #g-global-nav-container,
  #g-app-footer-container
    display none !important

  #g-app-body-container
    margin-left 0 !important
    padding 0 !important

.g-project-page,
.g-dashboard
  min-height 100vh
  padding 34px
  font-family 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif
  color #1e293b
  background linear-gradient(135deg, var(--bg), var(--bg2))

.g-smartit-theme
  --primary #16324F
  --secondary #4F46E5
  --bg #f5f7ff
  --bg2 #eaf0ff

.g-project-header
  display flex
  justify-content space-between
  align-items center
  gap 24px
  background white
  border 1px solid rgba(0,0,0,0.06)
  border-radius 28px
  padding 24px 32px
  box-shadow 0 16px 45px rgba(22,50,79,0.10)
  margin-bottom 40px

.g-brand
  display flex
  align-items center
  gap 18px
  min-width 0

.g-brand-icon
  min-width 64px
  width 64px
  height 64px
  border-radius 22px
  display flex
  align-items center
  justify-content center
  font-size 34px
  background linear-gradient(135deg, var(--primary), var(--secondary))
  color white

.g-brand h1
  margin 0
  font-size 30px
  font-weight 900
  color var(--primary)

.g-brand p
  margin 6px 0 0
  font-size 15px
  color #64748b

.g-auth
  display flex
  gap 12px
  align-items center
  flex-wrap wrap
  justify-content flex-end

.g-btn,
.g-main-btn,
.g-secondary-btn
  min-height 44px
  border none
  border-radius 14px
  padding 0 22px
  font-weight 800
  cursor pointer
  transition all 0.2s ease
  white-space nowrap
  line-height 44px
  font-size 15px

.g-btn
  min-width 58px
  background var(--primary)
  color white

.g-main-btn
  background white
  color var(--primary)

.g-secondary-btn
  background rgba(255,255,255,0.16)
  color white
  border 1px solid rgba(255,255,255,0.45)

.g-language-switcher
  background var(--secondary)
  color white

.g-btn:hover,
.g-main-btn:hover,
.g-secondary-btn:hover
  transform translateY(-3px)

.g-hero
  min-height 440px
  display flex
  align-items center
  justify-content center
  text-align center
  border-radius 34px
  padding 70px 40px
  color white
  background linear-gradient(135deg, var(--primary), var(--secondary))
  box-shadow 0 26px 70px rgba(30,58,95,0.22)

.g-badge
  display inline-block
  padding 10px 18px
  border-radius 999px
  background rgba(255,255,255,0.18)
  border 1px solid rgba(255,255,255,0.3)
  font-weight 800
  margin-bottom 20px

.g-hero h2
  font-size 68px
  font-weight 950
  margin 0 0 22px
  letter-spacing -1.5px

.g-hero p
  max-width 820px
  margin 0 auto 38px
  font-size 23px
  line-height 1.55
  opacity 0.95

.g-hero-actions
  display flex
  justify-content center
  gap 18px
  flex-wrap wrap

.g-cards,
.g-dashboard-grid
  display grid
  grid-template-columns repeat(auto-fit, minmax(260px, 1fr))
  gap 28px
  margin-top 40px

.g-card,
.g-dashboard-card
  background white
  border 1px solid rgba(0,0,0,0.06)
  border-radius 28px
  padding 34px
  box-shadow 0 16px 45px rgba(30,58,95,0.09)
  text-decoration none
  color #1e293b
  transition all 0.22s ease

.g-card:hover,
.g-dashboard-card:hover
  transform translateY(-7px)
  box-shadow 0 24px 65px rgba(30,58,95,0.15)

.g-card-icon,
.g-dashboard-card span
  font-size 44px

.g-card h3,
.g-dashboard-card h3
  font-size 25px
  color var(--primary)
  margin 18px 0 12px
  font-weight 900

.g-card p,
.g-dashboard-card p
  font-size 16px
  line-height 1.6
  color #64748b

.g-dashboard-hero
  background linear-gradient(135deg, var(--primary), var(--secondary))
  color white
  padding 42px 58px 58px
  border-radius 32px
  box-shadow 0 24px 65px rgba(30,58,95,0.22)

.g-dashboard-topbar
  display flex
  justify-content flex-end
  margin-bottom 22px

.g-language-pill
  min-width 58px
  height 42px
  padding 0 18px
  border none
  border-radius 999px
  background rgba(255,255,255,0.18)
  color white
  font-weight 900
  cursor pointer
  transition all 0.2s ease

  &:hover
    background rgba(255,255,255,0.28)
    transform translateY(-2px)

.g-dashboard-hero h1
  font-size 46px
  margin 0 0 14px
  font-weight 950

.g-dashboard-hero p
  font-size 20px
  margin 0
  opacity 0.95

@media (max-width: 720px)
  .g-project-page,
  .g-dashboard
    padding 18px

  .g-project-header
    flex-direction column
    gap 20px
    text-align center

  .g-auth
    justify-content center

  .g-hero
    padding 50px 20px

  .g-hero h2
    font-size 42px

  .g-hero p
    font-size 18px

.g-brand-logo
  min-width 64px
  width 64px
  height 64px
  border-radius 22px
  display flex
  align-items center
  justify-content center
  background white
  border 1px solid rgba(0,0,0,0.06)
  overflow hidden

  img
    width 48px
    height 48px
    object-fit contain