$navLinkBorder=1px solid rgba(37,99,235,0.18)
$emptyBorder=1px solid transparent
$minHeight=500px

#g-global-nav-container
  background #ffffff
  border-right 1px solid rgba(37,99,235,0.18)
  box-shadow 8px 0 28px rgba(22,50,79,0.10)

.g-global-nav-main
  min-height $minHeight - 12px
  padding 24px 12px
  background #ffffff
  box-shadow none

ul.g-global-nav
  padding-left 0
  margin 0

  > li
    list-style-type none
    border $emptyBorder
    margin 8px 0
    border-radius 16px
    transition all 0.2s ease

  > li:hover:not(.g-active)
    background #edf4ff

    .g-nav-link
      color #2563EB

    i
      color #2563EB

  > li.g-active
    background #edf4ff
    border $navLinkBorder
    box-shadow 0 8px 20px rgba(22,50,79,0.10)

    .g-nav-link
      color #16324F

    i
      color #2563EB

.g-nav-link
  display flex
  align-items center
  gap 10px
  padding 13px 16px
  line-height 1.4
  font-size 17px
  font-weight 700
  color #16324F
  text-decoration none

  &:hover
    text-decoration none

  i
    color #2563EB
    font-size 18px
    margin 0
